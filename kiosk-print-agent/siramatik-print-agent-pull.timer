# Günde iki kez ve acilisten ~10 dk sonra rastgele gecikmeyle calisir.
# Zamanlari degistirmek icin OnCalendar satirlarini duzenleyin.

[Unit]
Description=Siramatik depo otomatik guncelleme zamanlayicisi

[Timer]
OnBootSec=10min
OnCalendar=*-*-* 03:00:00
OnCalendar=*-*-* 15:00:00
RandomizedDelaySec=300
Persistent=true

[Install]
WantedBy=timers.target
